{
  "version": "2.5.1",
  "license": "MIT",
  "name": "jbrowse-plugin-msaview",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/jbrowse-plugin-msaview.git"
  },
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "start": "node esbuild.mjs --watch",
    "format": "pnpm prettier --write .",
    "build": "tsc && NODE_ENV=production node esbuild.mjs && cp distconfig.json dist/config.json",
    "prebuild": "pnpm clean",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "pretest": "rm -rf .test-jbrowse && npx @jbrowse/cli create .test-jbrowse --nightly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "node scripts/test-versions.mjs setup",
    "test:setup:version": "node scripts/test-versions.mjs setup",
    "test:versions": "node scripts/test-versions.mjs run",
    "test:version": "node scripts/test-versions.mjs run",
    "prepack": "pnpm build",
    "preversion": "pnpm lint",
    "version": "node -e \"console.log('export const version = \\'' + require('./package.json').version + '\\'')\" > src/version.ts && git add src/version.ts",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@emotion/styled": "^11.14.1",
    "g2p_mapper": "^2.1.5",
    "idb": "^8.0.3",
    "pako-esm2": "^2.0.2",
    "react-msaview": "^5.4.1",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@eslint/js": "^10.0.1",
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@jbrowse/core": "^4.3.0",
    "@jbrowse/mobx-state-tree": "^5.10.8",
    "@jbrowse/plugin-linear-genome-view": "^4.3.0",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/system": "^7.3.11",
    "@mui/x-data-grid": "^8.28.7",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "mobx": "^6.15.4",
    "mobx-react": "^9.2.2",
    "msa-parsers": "5.4.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "pretty-bytes": "^7.1.0",
    "puppeteer": "^25.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "serve": "^14.2.6",
    "tss-react": "^4.9.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
