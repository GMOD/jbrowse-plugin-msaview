{
  "version": "2.2.11",
  "license": "MIT",
  "name": "jbrowse-plugin-msaview",
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "start": "node esbuild.mjs --watch",
    "format": "prettier --write .",
    "build": "tsc && NODE_ENV=production node esbuild.mjs && cp distconfig.json dist/config.json",
    "prebuild": "yarn clean",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "pretest": "rm -rf .test-jbrowse && npx @jbrowse/cli create .test-jbrowse --nightly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "node scripts/test-versions.mjs setup",
    "test:setup:version": "node scripts/test-versions.mjs setup",
    "test:versions": "node scripts/test-versions.mjs run",
    "test:version": "node scripts/test-versions.mjs run",
    "prepack": "yarn build",
    "prepublishOnly": "node -e \"console.log('export const version = \\'' + require('./package.json').version + '\\'')\" > src/version.ts && git add -A src && git diff --cached --quiet || git commit -m '[skip ci] Bump version.ts'",
    "preversion": "yarn lint",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@emotion/styled": "^11.14.1",
    "g2p_mapper": "^2.0.0",
    "idb": "^8.0.3",
    "pako-esm2": "^2.0.2",
    "react-msaview": "^5.0.7",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@eslint/js": "^9.39.4",
    "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
    "@jbrowse/core": "^4.1.15",
    "@jbrowse/mobx-state-tree": "^5.6.0",
    "@jbrowse/plugin-linear-genome-view": "^4.1.15",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@mui/system": "^7.3.10",
    "@mui/x-data-grid": "^8.28.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "mobx": "^6.15.0",
    "mobx-react": "^9.2.1",
    "prettier": "^3.8.2",
    "pretty-bytes": "^7.1.0",
    "puppeteer": "^24.40.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "serve": "^14.2.6",
    "tss-react": "^4.9.20",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
